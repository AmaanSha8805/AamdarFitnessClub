generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Manager {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(MANAGER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GymSettings {
  id             String   @id @default("default")
  gymName        String   @default("AAMDAR Fitness Club")
  logoUrl        String?
  address        String?
  contactNumber  String?
  email          String?
  openingTime    String?  @default("05:30")
  closingTime    String?  @default("21:00")
  facebookUrl    String?
  instagramUrl   String?
  youtubeUrl     String?
  twitterUrl     String?
  whatsappNumber String?
  updatedAt      DateTime @updatedAt
}

model Branch {
  id            String       @id @default(cuid())
  name          String
  address       String?
  contactNumber String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  attendances   Attendance[]
  equipment     Equipment[]
  lockers       Locker[]
  members       Member[]
}

model MembershipPlan {
  id          String              @id @default(cuid())
  name        String              @unique
  duration    Int
  price       Decimal             @db.Decimal(12, 2)
  description String?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  planType    PlanType            @default(MONTHLY)
  members     Member[]
  history     MembershipHistory[]
}

model Member {
  id                    String              @id @default(cuid())
  fullName              String
  mobileNumber          String              @unique
  email                 String?
  address               String?
  age                   Int?
  gender                Gender
  photoUrl              String?
  planId                String?
  joiningDate           DateTime
  expiryDate            DateTime
  status                MemberStatus        @default(ACTIVE)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  memberCode            String              @unique
  dateOfBirth           DateTime?
  height                Decimal?            @db.Decimal(5, 2)
  weight                Decimal?            @db.Decimal(5, 2)
  fitnessGoal           String?
  medicalNotes          String?
  emergencyContactName  String?
  emergencyContactPhone String?
  branchId              String?
  trainerId             String?
  attendances           Attendance[]
  lockerAssignments     LockerAssignment[]
  branch                Branch?             @relation(fields: [branchId], references: [id])
  plan                  MembershipPlan?     @relation(fields: [planId], references: [id])
  trainer               Trainer?            @relation(fields: [trainerId], references: [id])
  dietAssignments       MemberDiet[]
  workoutAssignments    MemberWorkout[]
  membershipHistory     MembershipHistory[]
  notifications         Notification[]
  payments              Payment[]
  progressEntries       ProgressEntry[]
  reminders             ReminderLog[]

  @@index([status])
  @@index([expiryDate])
  @@index([memberCode])
}

model MembershipHistory {
  id        String           @id @default(cuid())
  memberId  String
  planId    String?
  action    MembershipAction
  startDate DateTime
  endDate   DateTime
  amount    Decimal?         @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime         @default(now())
  member    Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  plan      MembershipPlan?  @relation(fields: [planId], references: [id])

  @@index([memberId])
}

model Payment {
  id            String        @id @default(cuid())
  memberId      String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  date          DateTime
  notes         String?
  status        PaymentStatus @default(PAID)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  receiptNumber String?       @unique
  member        Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([status])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  phone     String
  email     String?
  goal      String?
  notes     String?
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
}

model Trainer {
  id             String              @id @default(cuid())
  name           String
  photoUrl       String?
  experience     Int
  specialization String
  certifications String?
  contact        String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  email          String?
  salary         Decimal?            @db.Decimal(12, 2)
  joinDate       DateTime?
  active         Boolean             @default(true)
  members        Member[]
  notifications  Notification[]
  attendances    TrainerAttendance[]
  salaries       TrainerSalary[]
  workoutPlans   WorkoutPlan[]
}

model TrainerAttendance {
  id        String    @id @default(cuid())
  trainerId String
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  trainer   Trainer   @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId, date])
}

model TrainerSalary {
  id        String        @id @default(cuid())
  trainerId String
  amount    Decimal       @db.Decimal(12, 2)
  month     DateTime
  paidAt    DateTime?
  status    PaymentStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  trainer   Trainer       @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
}

model Expense {
  id        String          @id @default(cuid())
  title     String
  amount    Decimal         @db.Decimal(12, 2)
  category  ExpenseCategory
  date      DateTime
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([date])
  @@index([category])
}

model ReminderLog {
  id       String          @id @default(cuid())
  memberId String
  type     ReminderType
  channel  ReminderChannel
  message  String
  sentAt   DateTime        @default(now())
  member   Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([channel])
}

model Attendance {
  id        String         @id @default(cuid())
  memberId  String
  branchId  String?
  checkIn   DateTime
  checkOut  DateTime?
  type      AttendanceType @default(MANUAL)
  notes     String?
  createdAt DateTime       @default(now())
  branch    Branch?        @relation(fields: [branchId], references: [id])
  member    Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([checkIn])
  @@index([memberId])
}

model Exercise {
  id              String   @id @default(cuid())
  name            String
  muscleGroup     String?
  description     String?
  equipmentNeeded String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WorkoutPlan {
  id          String          @id @default(cuid())
  name        String
  description String?
  exercises   Json            @default("[]")
  trainerId   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assignments MemberWorkout[]
  trainer     Trainer?        @relation(fields: [trainerId], references: [id])
}

model MemberWorkout {
  id            String       @id @default(cuid())
  memberId      String
  workoutPlanId String
  assignedAt    DateTime     @default(now())
  active        Boolean      @default(true)
  member        Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workoutPlan   WorkoutPlan  @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  logs          WorkoutLog[]

  @@index([memberId])
}

model WorkoutLog {
  id              String        @id @default(cuid())
  memberWorkoutId String
  date            DateTime
  completed       Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  memberWorkout   MemberWorkout @relation(fields: [memberWorkoutId], references: [id], onDelete: Cascade)
}

model DietPlan {
  id          String       @id @default(cuid())
  name        String
  description String?
  calories    Int?
  meals       Json         @default("[]")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments MemberDiet[]
}

model MemberDiet {
  id         String   @id @default(cuid())
  memberId   String
  dietPlanId String
  assignedAt DateTime @default(now())
  active     Boolean  @default(true)
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model ProgressEntry {
  id           String   @id @default(cuid())
  memberId     String
  date         DateTime
  weight       Decimal? @db.Decimal(5, 2)
  chest        Decimal? @db.Decimal(5, 2)
  waist        Decimal? @db.Decimal(5, 2)
  hips         Decimal? @db.Decimal(5, 2)
  bmi          Decimal? @db.Decimal(4, 2)
  photoUrl     String?
  goalProgress Int?
  notes        String?
  createdAt    DateTime @default(now())
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([date])
}

model Locker {
  id          String             @id @default(cuid())
  number      String
  branchId    String?
  status      LockerStatus       @default(AVAILABLE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  branch      Branch?            @relation(fields: [branchId], references: [id])
  assignments LockerAssignment[]

  @@unique([number, branchId])
}

model LockerAssignment {
  id         String    @id @default(cuid())
  lockerId   String
  memberId   String
  assignedAt DateTime  @default(now())
  releasedAt DateTime?
  locker     Locker    @relation(fields: [lockerId], references: [id], onDelete: Cascade)
  member     Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([lockerId])
}

model Equipment {
  id                 String                 @id @default(cuid())
  name               String
  brand              String?
  serialNumber       String?
  purchaseDate       DateTime?
  purchasePrice      Decimal?               @db.Decimal(12, 2)
  status             EquipmentStatus        @default(OPERATIONAL)
  branchId           String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  branch             Branch?                @relation(fields: [branchId], references: [id])
  maintenanceRecords EquipmentMaintenance[]

  @@index([status])
}

model EquipmentMaintenance {
  id              String          @id @default(cuid())
  equipmentId     String
  serviceDate     DateTime
  nextServiceDate DateTime?
  cost            Decimal?        @db.Decimal(12, 2)
  notes           String?
  status          EquipmentStatus @default(OPERATIONAL)
  createdAt       DateTime        @default(now())
  equipment       Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
}

model Notification {
  id           String           @id @default(cuid())
  type         NotificationType
  title        String
  message      String
  memberId     String?
  trainerId    String?
  channel      ReminderChannel?
  sentAt       DateTime?
  scheduledFor DateTime?
  createdAt    DateTime         @default(now())
  member       Member?          @relation(fields: [memberId], references: [id])
  trainer      Trainer?         @relation(fields: [trainerId], references: [id])

  @@index([type])
  @@index([scheduledFor])
}

enum Role {
  MANAGER
  ADMIN
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  PENDING
  INACTIVE
}

enum PlanType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUAL
  CUSTOM
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  CONVERTED
  REJECTED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PAID
  PENDING
}

enum ExpenseCategory {
  RENT
  ELECTRICITY
  SALARY
  MAINTENANCE
  MISCELLANEOUS
}

enum ReminderType {
  SEVEN_DAYS
  THREE_DAYS
  EXPIRY_DAY
  PENDING_PAYMENT
  BIRTHDAY
  ATTENDANCE
  PROMOTIONAL
}

enum ReminderChannel {
  WHATSAPP
  EMAIL
}

enum EquipmentStatus {
  OPERATIONAL
  MAINTENANCE
  OUT_OF_SERVICE
}

enum LockerStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum NotificationType {
  MEMBERSHIP_EXPIRY
  PAYMENT_DUE
  BIRTHDAY
  ANNOUNCEMENT
  TRAINER
  ATTENDANCE
  PROMOTIONAL
}

enum AttendanceType {
  MANUAL
  QR_CODE
}

enum MembershipAction {
  NEW
  RENEWAL
  UPGRADE
  DOWNGRADE
}
